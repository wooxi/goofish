# Docker / local shared environment
BACKEND_PORT=8001
FRONTEND_PORT=8080

# Upstream OpenAPI base for backend
GOOFISH_API_BASE=https://open.goofish.pro

# Frontend build-time API base URL (empty = same-origin)
VITE_API_BASE_URL=

# CORS for backend
CORS_ALLOW_ORIGINS=http://localhost:8080
CORS_ALLOW_METHODS=*
CORS_ALLOW_HEADERS=*
CORS_ALLOW_CREDENTIALS=false
